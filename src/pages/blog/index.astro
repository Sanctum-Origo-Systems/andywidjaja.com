---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Base title="Blog | Andy Widjaja">
  <Header />

  <main class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-semibold mb-10">Blog</h1>

    <div class="space-y-8">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="block group">
          <time class="font-mono text-text-secondary text-xs">{post.data.date.toISOString().split('T')[0]}</time>
          <h2 class="text-lg font-semibold text-text-primary group-hover:text-accent transition-colors mt-1">
            {post.data.title}
          </h2>
          <p class="text-text-secondary text-sm mt-1">{post.data.description}</p>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</Base>
