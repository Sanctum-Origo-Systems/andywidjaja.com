---
---

<header class="max-w-3xl mx-auto px-6 py-8 flex items-center justify-between">
  <a href="/" class="text-text-primary font-semibold text-lg hover:text-accent transition-colors">
    Andy Widjaja
  </a>
  <nav class="flex items-center gap-4">
    <a
      href="https://github.com/Sanctum-Origo-Systems"
      target="_blank"
      rel="noopener noreferrer"
      class="text-text-secondary hover:text-accent transition-colors font-mono text-sm"
    >
      GitHub &rarr;
    </a>
    <button
      id="theme-toggle"
      type="button"
      aria-label="Toggle dark mode"
      class="text-text-secondary hover:text-accent transition-colors cursor-pointer text-lg leading-none p-1"
    >
      <span id="theme-icon-light" class="hidden dark:inline">&#x2600;&#xFE0E;</span>
      <span id="theme-icon-dark" class="inline dark:hidden">&#x263E;&#xFE0E;</span>
    </button>
  </nav>
</header>

<script is:inline>
  document.getElementById('theme-toggle').addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
